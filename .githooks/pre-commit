#!/bin/sh
set -eu

if git diff --cached -U0 --no-ext-diff | grep -E '^\+.*(AKIA[0-9A-Z]{16}|sk-[A-Za-z0-9_-]{20,}|api[_-]?key[[:space:]]*[:=][[:space:]]*["'\''][^"'\'']+)' >/dev/null 2>&1; then
  echo "Commit blocked: staged changes appear to contain a secret."
  exit 1
fi

npm run lint -- --max-warnings=0
