{
  "name": "zhiyan-assistant",
  "version": "0.1.0-alpha.1",
  "description": "智研助手 - 面向大学教师的无代码教学科研 AI 工作台",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "npm run build:kun && electron-vite dev",
    "build": "npm run build:kun && electron-vite build",
    "build:kun": "node ./scripts/ensure-kun-install.cjs && npm --prefix kun run build",
    "lint": "eslint .",
    "hooks:install": "git config core.hooksPath .githooks",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist": "npm run build && npx --yes electron-builder@26.8.1 --config electron-builder.config.cjs --publish never",
    "dist:mac": "npm run build && npx --yes electron-builder@26.8.1 --config electron-builder.config.cjs --publish never --mac dmg zip",
    "dist:mac:signed": "MAC_SIGN=1 npm run dist:mac",
    "dist:win": "npm run dist -- --win nsis --x64",
    "dist:linux": "npm run dist -- --linux AppImage --x64",
    "postinstall": "node ./scripts/postinstall.cjs",
    "verify:apple": "node ./scripts/verify-apple-signing.cjs",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1049.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@larksuiteoapi/node-sdk": "^1.64.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tencent-weixin/openclaw-weixin": "2.4.3",
    "better-sqlite3": "^12.10.0",
    "electron-store": "^10.1.0",
    "electron-updater": "^6.8.3",
    "fast-xml-parser": "^5.8.0",
    "html-to-docx": "^1.8.0",
    "i18next": "^25.4.2",
    "image-size": "^2.0.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.544.0",
    "openclaw": "file:vendor/openclaw-shim",
    "pdfjs-dist": "^4.8.69",
    "pptxgenjs": "^4.0.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.7.4",
    "react-markdown": "^10.1.0",
    "rehype-harden": "^1.1.8",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.23.0",
    "streamdown": "^2.5.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/html-to-docx": "^1.8.1",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "electron": "^34.5.8",
    "electron-vite": "^3.1.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.59.4",
    "vite": "^6.2.0",
    "vitest": "^4.1.7"
  },
  "author": "ZhiYan Assistant"
}
